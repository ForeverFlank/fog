{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "fog",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#keywords" },
        { "include": "#constants" },
        { "include": "#types" },
        { "include": "#functions" },
        { "include": "#operators" },
        { "include": "#variables" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-dash.fog",
                    "match": "--.*$"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.fog",
                    "match": "\\b(if|match|else)\\b"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.fog",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.fog",
                    "match": "\\\\."
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.integer.fog",
                    "match": "\\b\\d+\\b"
                },
                {
                    "name": "constant.numeric.float.fog",
                    "match": "\\b\\d+\\.\\d+\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "entity.name.type.fog",
                    "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.fog",
                    "match": "=|:|->|\\+|-|\\*|\/"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.other.fog",
                    "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
                }
            ]
        }
    },
    "scopeName": "source.fog"
}

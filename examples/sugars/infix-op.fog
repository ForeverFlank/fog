-- prerequisite: ad hoc polymorphism with infix operators

num1 = 2 + 3    -- 5
num2 = 9 - 8    -- 1
num3 = 5 * 6    -- 30


Point : Type
Point = Int32 * Int32

Add Point = {
    (x1, y1) + (x2, y2) = (x1 + x2, y1 + y2)
}

p1 : Point
p1 = (2, 3)

p2 : Point
p2 = (4, 5)

p3 : Point
p3 = p1 + p2    -- (6, 8)

-- right pipe
|> : (a -> b) -> a -> b
x |> f = f x

-- left pipe
<| : a -> (a -> b) -> b
f <| x = f x

-- right composition
>> : (a -> b) -> (b -> c) -> (a -> c)
f >> g = x => g (f x)

-- left composition
<< : (b -> c) -> (a -> b) -> (a -> c)
f << g = x => f (g x)

-- unfortunately, fog's left composition operator
-- is not a literal 'o' letter.

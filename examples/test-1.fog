// traditional declaration
let fib : int -> int
fib(n) = {
    if n = 0 {
        return 0
    }
    if n = 1 {
        return 1
    }
    return fib(n - 1) + fib(n - 2)
}

// declare by assigning lambda
let collatz : int -> int
collatz = (x) => {
    if x mod 2 = 0 {
        return x / 2
    }
    return 3 * x + 1
}

var x : int = 10
x <- fib(x)
while x != 1 {
    x <- collatz(x)
}


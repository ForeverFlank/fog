// set
let s1 : Set<int>
let s1 = {1, 2, 2, 3, 5, 6}
let s2 = {4, 6, 8, 2}
let s3 = Set.union(s1, s2)
let s4 = Set.intersection(s1, s2)
let s5 = s1 - s2
let cart = s1 * s2


-- compositions --

<< : (T2 -> T3) -> (T1 -> T2) -> (T1 -> T3)
f << g = x => f g x

>> : (T1 -> T2) -> (T2 -> T3) -> (T1 -> T3)
f >> g = x => g f x


-- pipes --

<| : (T1 -> T2) -> T1 -> T2
f <| x = f x

|> : T1 -> (T1 -> T2) -> T2
x |> f = f x


-- examples --

f : Int32 -> Int32
f x = x^2

g : Int32 -> Int32
g x = 2 * x

fog : Int32 -> Int32
fog = f << g


string = 67 |> fog |> toString      -- 17956

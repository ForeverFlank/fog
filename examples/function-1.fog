fib1 : Int32 -> Int32
fib1 0 = 0
fib1 1 = 1
fib1 n = fib1 (n - 1) + fib1 (n - 2)

fib2 : Int32 -> Int32
fib2 n =
    | n == 0, 0
    | n == 1, 1
    | else,   fib2 (n - 1) + fib2 (n - 2)

fib3 : Int32 -> Int32
fib3 n =
    if n == 0
        0
    if n == 1
        1
    else
        fib3 (n - 1) + fib3 (n - 2)

-- ad-hoc polymorphism
-- commonly known as interfaces

--- style 1 ---

Equatable : Type -> Constraint
Equatable t = {
    == : t -> t -> Bool
    != : t -> t -> Bool

    -- a == b = not (a != b)
    -- a != b = not (a == b)
}

-- not sure about this one yet
PartialOrdered : Equatable -> Constraint
PartialOrdered t {
    <= : t -> t -> Bool
}

--- style 2 ---

trait Equatable t {
    == : t -> t -> Bool
}

trait PartialOrdered t
impl Equatable {
    <= : t -> t -> Bool
}
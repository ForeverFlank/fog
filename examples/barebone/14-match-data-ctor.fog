-- matching data constructors

-- shape type, described by side lengths
Shape : Type
Shape = Tri Int32 Int32 Int32 + Quad Int32 Int32 Int32 Int32

perimeter : Shape -> Int32
perimeter = shape : Shape => match shape {
    Tri s1 s2 s3    => addInt32 (addInt32 s1 s2) s3
    Quad s1 s2 s3 s4 => addInt32 (addInt32 (addInt32 s1 s2) s3) s4
}

num1 : Int32
num1 = perimeter (Tri 3 4 5)        -- 12

num2 : Int32
num2 = perimeter (Quad 6 7 8 9)     -- 30

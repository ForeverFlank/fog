// meta int definition
// built into interpreter/vm

let int : type {
    let + : int * int -> int
        +(lhs, rhs) = _builtin_add(lhs, rhs)

    let * : int * int -> int
        *(lhs, rhs) = _builtin_mul(lhs, rhs)

    // not declared
    let - : int -> int
}

// operator overloading
int.-(lhs, rhs) = _builtin_sub(lhs, rhs)

let mutable i : int = 0
while i < 10 {
    i <- i + 1
    print(i)
}


